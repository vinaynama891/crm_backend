datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  SALES_MANAGER
  SALES_AGENT
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum LeadStatus {
  New
  Contacted
  Interested
  SiteVisitScheduled
  Negotiation
  Booked
  Lost
  NotResponding
}

enum LeadTemperature {
  Cold
  Warm
  Hot
}

enum Availability {
  Available
  Hold
  Sold
}

enum ShareChannel {
  WHATSAPP
  EMAIL
}

enum ActivityType {
  CALL
  WHATSAPP
  NOTE
  SHARE
  FOLLOWUP
  STATUS_CHANGE
  SITE_VISIT
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  SNOOZED
  RESCHEDULED
}

enum SiteVisitStatus {
  Scheduled
  Completed
  Cancelled
  NoShow
}

enum NotificationType {
  NEW_LEAD
  FOLLOWUP_DUE
  SITE_VISIT_REMINDER
  MISSED_LEAD
  PROPERTY_SHARED
}

enum AssignmentMode {
  ROUND_ROBIN
  LEAST_BUSY
  MANUAL
}

model Organization {
  id                  String               @id @default(uuid())
  name                String
  slug                String               @unique
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  teamMembers         TeamMember[]
  leads               Lead[]
  properties          Property[]
  siteVisits          SiteVisit[]
  followups           FollowUp[]
  activities          Activity[]
  calls               Call[]
  messages            Message[]
  propertyShares      PropertyShare[]
  notifications       Notification[]
  integrationSettings IntegrationSettings?

  @@map("organizations")
}

model Profile {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String         @map("password_hash")
  fullName      String         @map("full_name")
  phone         String?
  avatarUrl     String?        @map("avatar_url")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  teamMembers   TeamMember[]
  notifications Notification[]

  @@map("profiles")
}

model TeamMember {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  profileId      String          @map("profile_id")
  role           Role
  status         MemberStatus    @default(ACTIVE)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  profile        Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  assignedLeads  Lead[]
  calls          Call[]
  shares         PropertyShare[]
  siteVisits     SiteVisit[]
  followups      FollowUp[]
  activities     Activity[]
  messages       Message[]

  @@map("team_members")
}

model Lead {
  id                String          @id @default(uuid())
  organizationId    String          @map("organization_id")
  fullName          String          @map("full_name")
  phone             String
  email             String?
  source            String
  propertyType      String?         @map("property_type")
  budget            Float?
  preferredLocation String?         @map("preferred_location")
  status            LeadStatus      @default(New)
  temperature       LeadTemperature @default(Cold)
  assignedAgentId   String?         @map("assigned_agent_id")
  notes             String?
  followupDate      DateTime?       @map("followup_date")
  firstCallAt       DateTime?       @map("first_call_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedAgent     TeamMember?     @relation(fields: [assignedAgentId], references: [id], onDelete: SetNull)
  activities        Activity[]
  calls             Call[]
  messages          Message[]
  propertyShares    PropertyShare[]
  siteVisits        SiteVisit[]
  followups         FollowUp[]

  @@map("leads")
}

model Property {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  title          String
  projectName    String          @map("project_name")
  location       String
  address        String
  propertyType   String          @map("property_type")
  price          Float
  size           String
  bedrooms       Int
  bathrooms      Int
  description    String
  amenities      String[]
  availability   Availability    @default(Available)
  brochureUrl    String?         @map("brochure_url")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  images         PropertyImage[]
  shares         PropertyShare[]
  siteVisits     SiteVisit[]

  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String   @map("property_id")
  imageUrl   String   @map("image_url")
  createdAt  DateTime @default(now()) @map("created_at")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model PropertyShare {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  leadId         String       @map("lead_id")
  agentId        String       @map("agent_id")
  propertyId     String       @map("property_id")
  channel        ShareChannel
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  agent          TeamMember   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  property       Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_shares")
}

model Activity {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  leadId         String       @map("lead_id")
  agentId        String?      @map("agent_id")
  type           ActivityType
  content        String
  referenceId    String?      @map("reference_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  agent          TeamMember?  @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@map("activities")
}

model Call {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  leadId         String       @map("lead_id")
  agentId        String       @map("agent_id")
  callSid        String       @map("call_sid")
  duration       Int
  recordingUrl   String?      @map("recording_url")
  outcome        String
  startedAt      DateTime     @map("started_at")
  endedAt        DateTime     @map("ended_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  agent          TeamMember   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("calls")
}

model Message {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  leadId         String       @map("lead_id")
  agentId        String?      @map("agent_id")
  templateName   String       @map("template_name")
  messageBody    String       @map("message_body")
  status         String
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  agent          TeamMember?  @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@map("messages")
}

model FollowUp {
  id             String         @id @default(uuid())
  organizationId String         @map("organization_id")
  leadId         String         @map("lead_id")
  agentId        String         @map("agent_id")
  title          String
  notes          String?
  scheduledAt    DateTime       @map("scheduled_at")
  status         FollowUpStatus @default(PENDING)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead           Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  agent          TeamMember     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("followups")
}

model SiteVisit {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  leadId         String          @map("lead_id")
  agentId        String          @map("agent_id")
  propertyId     String          @map("property_id")
  scheduledAt    DateTime        @map("scheduled_at")
  status         SiteVisitStatus @default(Scheduled)
  notes          String
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead           Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  agent          TeamMember      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  property       Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("site_visits")
}

model Notification {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  userId         String           @map("user_id")
  title          String
  message        String
  read           Boolean          @default(false)
  type           NotificationType
  createdAt      DateTime         @default(now()) @map("created_at")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model IntegrationSettings {
  id             String         @id @default(uuid())
  organizationId String         @unique @map("organization_id")
  twilioSid      String?        @map("twilio_sid")
  twilioToken    String?        @map("twilio_token")
  twilioNumber   String?        @map("twilio_number")
  whatsappNumber String?        @map("whatsapp_number")
  resendApiKey   String?        @map("resend_api_key")
  webhookSecret  String?        @map("webhook_secret")
  assignmentMode AssignmentMode @default(ROUND_ROBIN) @map("assignment_mode")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("integration_settings")
}
